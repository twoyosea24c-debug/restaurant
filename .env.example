# Local SQLite development
DATABASE_URL="file:./dev.db"

# Production PostgreSQL example
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Change both values before production deploy.
ADMIN_PASSWORD="replace-with-a-strong-admin-password"
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Set this to your deployed URL when the hosting provider requires it.
NEXT_PUBLIC_APP_URL="https://example.com"

# SMTP_HOST / SMTP_PORT / MAIL_FROM が未設定の場合、メールは送信せずログだけ出します。
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM=""
NOTIFICATION_EMAIL=""
