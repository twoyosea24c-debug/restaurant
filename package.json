{
  "name": "small-store-base",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pg": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "check": "tsc --noEmit",
    "db:push": "tsx prisma/init-sqlite.ts && prisma generate",
    "db:init": "tsx prisma/init-sqlite.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:pg:push": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:pg:generate": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "next": "^16.0.7",
    "nodemailer": "^8.0.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
